# ── HikingPoll environment variables ──────────────────────────────────────────
# Local development needs NOTHING here — the app uses an embedded database
# (PGlite) that saves to a local ./.pglite folder automatically.
#
# For production on Vercel, set these two variables in your Vercel project:

# 1) Your Neon Postgres connection string.
#    Get it free: Vercel Dashboard → your project → Storage → Create Database → Neon.
#    Vercel usually injects this automatically as DATABASE_URL after you connect Neon.
DATABASE_URL=

# 2) The password you'll type to open the /admin dashboard. Pick something private.
ADMIN_PASSWORD=change-me
